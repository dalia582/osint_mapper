# OSINT Mapper — Protection des fichiers sensibles

# Protéger les fichiers JSON de données
<Files "*.json">
    Order Allow,Deny
    Deny from all
</Files>

# Activer la compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# Headers de sécurité
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Interdire l'accès aux fichiers de config
<FilesMatch "^(api_external|clear-data)\.php$">
    Order Allow,Deny
    Allow from all
</FilesMatch>
